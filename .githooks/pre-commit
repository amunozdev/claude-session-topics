#!/bin/bash
# Pre-commit hook for claude-session-topics
# Install with: cp .githooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# Or use: git config core.hooksPath .githooks

set -euo pipefail

echo "Running pre-commit checks..."
echo ""

FAILED=0

# Function to run a check
run_check() {
    local name="$1"
    local cmd="$2"
    
    echo "  Checking: $name..."
    if eval "$cmd" > /dev/null 2>&1; then
        echo "    ✓ Passed"
        return 0
    else
        echo "    ✗ Failed"
        return 1
    fi
}

# Check shell scripts with shellcheck
if command -v shellcheck &> /dev/null; then
    if ! run_check "Shell scripts (shellcheck)" "shellcheck scripts/*.sh --severity=warning"; then
        echo "    Run: shellcheck scripts/*.sh --severity=warning"
        FAILED=1
    fi
else
    echo "  ⚠ shellcheck not installed, skipping shell script checks"
fi

# Check JavaScript with ESLint
if command -v pnpm &> /dev/null; then
    if ! run_check "JavaScript (ESLint)" "pnpm exec eslint bin/install.js"; then
        echo "    Run: pnpm exec eslint bin/install.js"
        FAILED=1
    fi
fi

# Check version consistency
if ! run_check "Version consistency" "pnpm run version:check"; then
    echo "    Run: pnpm run version:sync to fix"
    FAILED=1
fi

# Run tests
echo "  Running test suite..."
if ! ./test.sh > /tmp/pre-commit-tests.log 2>&1; then
    echo "    ✗ Tests failed"
    echo "    Run: ./test.sh for details"
    tail -20 /tmp/pre-commit-tests.log
    FAILED=1
else
    echo "    ✓ All tests passed"
fi

# Check for debugging code
echo "  Checking for debugging code..."
if grep -r "console.log(" bin/*.js scripts/*.js 2>/dev/null | grep -v "^Binary" | head -5; then
    echo "    ⚠ Found console.log statements (remove before commit)"
    # Don't fail, just warn
fi

# Summary
echo ""
if [ $FAILED -eq 0 ]; then
    echo "✓ All pre-commit checks passed!"
    exit 0
else
    echo "✗ Some checks failed. Fix before committing."
    exit 1
fi
