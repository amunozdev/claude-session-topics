{
  "name": "@alexismunozdev/claude-session-topics",
  "version": "5.0.1",
  "description": "Session topics for Claude Code — auto-set and display a topic in the statusline, change anytime with /set-topic",
  "bin": {
    "claude-session-topics": "bin/install.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:installer": "vitest run tests/installer/",
    "test:watch": "vitest",
    "version:check": "bash scripts/check-versions.sh",
    "version:sync": "node scripts/sync-versions.js",
    "lint": "shellcheck scripts/*.sh --severity=warning && npx eslint bin/install.js",
    "diagnose": "bash scripts/diagnose.sh"
  },
  "devDependencies": {
    "@vitest/ui": "^1.6.1",
    "eslint": "^9.0.0",
    "vitest": "^1.6.1"
  },
  "files": [
    "bin/",
    "hooks/",
    "scripts/",
    "skills/",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "statusline",
    "topic",
    "session",
    "productivity"
  ],
  "author": "Alexis Muñoz",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alexismunoz1/claude-session-topics.git"
  },
  "homepage": "https://github.com/alexismunoz1/claude-session-topics"
}
